Screens:
  Main screen:
    Properties:
      OnVisible: |-
        =UpdateContext({activescreen: "null"});
        UpdateContext({theme: "Light"})
    Children:
      - glb_header:
          Control: Header@0.0.44
          Properties:
            BasePaletteColor: =If(st_darkmode.Checked=true, RGBA(0, 0, 0, 1), RGBA(141, 229, 250, 1))
            Height: =35
            IsLogoVisible: =false
            IsProfilePictureVisible: =false
            Style: ='Header.Style'.Primary
            Title: ="TKE P&C Operation"
      - glb_menu:
          Control: GroupContainer@1.3.0
          Variant: ManualLayout
          Properties:
            Fill: =If(st_darkmode.Checked=true, RGBA(0, 0, 0, 1), RGBA(0, 0, 0, 0))
            Height: |+
              =Parent.Height-35
            Width: =9*Len(mn_icmapproval.Text)
            Y: =35
          Children:
            - hd_personal:
                Control: Button@0.0.45
                Properties:
                  Align: =Align.Left
                  Appearance: ='ButtonCanvas.Appearance'.Subtle
                  BasePaletteColor: =RGBA(189, 178, 176, 1)
                  FontColor: =RGBA(215, 58, 60, 1)
                  Text: ="Engineer"
                  Width: =Parent.Width
            - mn_notification:
                Control: Button@0.0.45
                Properties:
                  Align: =Align.Left
                  Appearance: =If(activescreen="notification", 'ButtonCanvas.Appearance'.Primary, 'ButtonCanvas.Appearance'.Subtle)
                  BasePaletteColor: =RGBA(141, 229, 250, 1)
                  OnSelect: |-
                    =UpdateContext({activescreen: "notification"});
                    Refresh('Internal_ App_Notifications')
                  Text: =Concatenate("Notification (", CountRows(Filter('Internal_ App_Notifications', Recipient.Email=User().Email)), ")")
                  Width: =Parent.Width
                  Y: =32
            - mn_checkday:
                Control: Button@0.0.45
                Properties:
                  Align: =Align.Left
                  Appearance: =If(activescreen="checkday", 'ButtonCanvas.Appearance'.Primary, 'ButtonCanvas.Appearance'.Subtle)
                  BasePaletteColor: =RGBA(141, 229, 250, 1)
                  OnSelect: |-
                    =UpdateContext({activescreen: "checkday"});
                    Refresh('Internal_ App_Notifications');
                    Refresh('TKE P&C Backlog Management');
                    Refresh('TKE P&C Backup tracking');
                    Refresh('TKE P&C Consultation requests');
                    Refresh('TKE P&C ICM approval requests');
                    Refresh('TKE P&C Recovery tracking');
                    Refresh('TKE P&C Engineers')
                  Text: |-
                    =Concatenate("To do (",
                    CountRows(Filter('TKE P&C Backlog Management', 'Created By'.Email=User().Email, And(Status.Value<>"Resolved", Status.Value<>"Pending recovery"), If(IsBlank('Next follow up')=true, 'Expected Followup'<=Today(), 'Next follow up'<=Today()))) +

                    CountRows(Filter('TKE P&C Recovery tracking', 'Owner (for reviewer only)'.Email=User().Email, And('Internal status 2'<>"Closed", 'Internal status 2'<>"Cancelled", 'Internal status 2'<>"Completed"), Or(IsBlank('Next contact date (for reviewer only)')=true, 'Next contact date (for reviewer only)'<=Today()))) +

                    CountRows(Filter('TKE P&C Recovery tracking', 'Created By'.Email=User().Email, Status.Value="Completed")) +

                    CountRows(Filter('TKE P&C Consultation requests', Reviewer.Email=User().Email, And(Status.Value<>"Completed", Status.Value<>"Provided information", Status.Value<>"Pending FTE", Status.Value<>"Requesting more details"))) +

                    CountRows(Filter('TKE P&C Consultation requests', 'Created By'.Email=User().Email, And(Status.Value<>"Completed", Status.Value<>"Pending", Status.Value<>"Reviewing"))) +

                    CountRows(Filter('TKE P&C ICM approval requests', Reviewer.Email=User().Email, And(Status.Value<>"Approved", Status.Value<>"Rejected", Status.Value<>"Approved for creation", Status.Value<>"Revision required"))) +

                    CountRows(Filter('TKE P&C ICM approval requests', 'Created By'.Email=User().Email, And(Status.Value<>"Approved", Status.Value<>"Rejected", Status.Value<>"Reviewing", Status.Value<>"Pending", Status.Value<>"Created"))) +

                    CountRows(Filter('TKE P&C Backup tracking', 'Backup engineer'.Email=User().Email, And('Start date'<=Today(), 'End date'>=Today())))
                    ,")")
                  Width: =Parent.Width
                  Y: =64
            - mn_kpi:
                Control: Button@0.0.45
                Properties:
                  Align: =Align.Left
                  Appearance: =If(activescreen="kpi", 'ButtonCanvas.Appearance'.Primary, 'ButtonCanvas.Appearance'.Subtle)
                  BasePaletteColor: =RGBA(141, 229, 250, 1)
                  OnSelect: |-
                    =UpdateContext({activescreen: "kpi"});
                    UpdateContext({rpt_sec1: true});
                    UpdateContext({activemonthkpi: true});
                    UpdateContext({rpt_sec2: false});
                    Refresh('Internal_ App_Notifications');
                    Refresh(Intenal_App_RawKPI)
                  Text: ="KPI"
                  Width: =Parent.Width
                  Y: =96
            - hd_task:
                Control: Button@0.0.45
                Properties:
                  Align: =Align.Left
                  Appearance: ='ButtonCanvas.Appearance'.Subtle
                  FontColor: =RGBA(215, 58, 60, 1)
                  Text: ="Daily tasks"
                  Width: =Parent.Width
                  Y: =192
            - mn_backlog:
