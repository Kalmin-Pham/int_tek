                  Appearance: =If(activescreen="schedule", 'ButtonCanvas.Appearance'.Primary, 'ButtonCanvas.Appearance'.Subtle)
                  BasePaletteColor: =RGBA(141, 229, 250, 1)
                  OnSelect: |-
                    =UpdateContext({activescreen: "schedule"});
                    Refresh('TKE PC - Schedule');
